# Copy to .env.local and fill in. Only VITE_-prefixed vars reach the client.
# `.env.local` is gitignored (*.local) — never commit real keys.

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
# REQUIRED for the web app. Without it the app builds in guest mode and the
# Annotate/Share auth gates are disabled (the web build fails fast — see
# scripts/check-web-env.mjs). Get it from the Clerk dashboard → API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ── Browser extension auth (Clerk Sync Host) ────────────────────────────────
# The extension shares the WEB APP's Clerk session (same VITE_CLERK_PUBLISHABLE_KEY
# above) via Sync Host: users sign in on the web app and the extension reads that
# session. No separate extension Clerk key.
#   - VITE_EXT_SYNC_HOST: origin whose Clerk cookies to sync (dev: http://localhost,
#     prod: your web app's Clerk domain, e.g. https://clerk.your-domain.com).
#   - VITE_EXT_WEB_APP_URL: the page the extension opens for sign-in.
# One-time: add chrome-extension://mkbkmeemombaioeikegphonpbjliljbm to the Clerk
# instance's allowed_origins (Clerk Backend API, needs the secret key).
VITE_EXT_SYNC_HOST=http://localhost
VITE_EXT_WEB_APP_URL=http://localhost:5173

# ── Data + realtime collab (Supabase) — OPTIONAL ─────────────────────────────
# Without these the app runs localStorage-only (no live collaboration).
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ── Subscriptions (Kelviq recurring billing) — OPTIONAL ──────────────────────
# Kelviq is a Merchant of Record (hosted checkout + customer portal + tax +
# 135+ currencies). Only the CLIENT (publishable) key and the product id go in
# the browser; the React SDK uses them to read live entitlements for gating.
# Checkout / upgrade / cancel / portal also need Supabase configured (above):
# they run in the supabase/functions/kelviq-* Edge Functions.
#   - VITE_KELVIQ_CLIENT_KEY:  Client API Key (Settings → API keys).
#   - VITE_KELVIQ_PRODUCT_ID:  the product your Free/Pro/Max plans live under.
#   - VITE_KELVIQ_ENV:         'sandbox' (default) or 'live'.
VITE_KELVIQ_CLIENT_KEY=kq_client_xxx
VITE_KELVIQ_PRODUCT_ID=prod_xxx
VITE_KELVIQ_ENV=sandbox
#
# SERVER SECRETS — set on Supabase, NEVER as VITE_ vars, NEVER in client code:
#   supabase secrets set KELVIQ_SERVER_KEY=… KELVIQ_WEBHOOK_SECRET=… CLERK_SECRET_KEY=…
# (CLERK_SECRET_KEY lets the kelviq-webhook mirror plan changes into Clerk.)
# For local `supabase functions serve`, put those in a gitignored
# supabase/functions/.env instead.

{
  "manifest_version": 3,
  "key": "",
  "name": "Sparoww — CSS Inspector & Annotator",
  "version": "1.0.0",
  "description": "Inspect CSS, measure layouts, pick colors and fonts, extract assets, and annotate any webpage — the Sparoww demo toolkit, on every site.",
  "action": {
    "default_title": "Toggle Sparoww Scanner",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "minimum_chrome_version": "121",
  "browser_specific_settings": {
    "gecko": {
      "id": "sparoww@trysparrowcss.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo"
        ]
      }
    }
  },
  "icons": {
    "48": "icons/icon48.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/content.css",
        "fonts/*.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
